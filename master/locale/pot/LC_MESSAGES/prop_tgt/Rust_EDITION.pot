#: ../../../prop_tgt/Rust_EDITION.rst:2
msgid "Rust_EDITION"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:7
msgid "Experimental. Gated by ``CMAKE_EXPERIMENTAL_RUST``."
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:9
msgid ""
"The Rust edition required to build this target. It is initialized from the :"
"variable:`CMAKE_Rust_EDITION` variable if defined. Setting this property "
"results in adding a flag such as ``--edition=2018`` to the compile line."
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:13
msgid "Supported values are:"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:15
msgid "``2015``"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:16
msgid "Rust 2015, the default edition, started with Rust 1.0."
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:18
msgid "``2018``"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:19
msgid "Rust 2018, available since Rust 1.31."
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:21
msgid "``2021``"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:22
msgid "Rust 2021, available since Rust 1.56."
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:24
msgid "``2024``"
msgstr ""

#: ../../../prop_tgt/Rust_EDITION.rst:25
msgid "Rust 2024, available since Rust 1.85."
msgstr ""
