msgid ""
"Use :prop_fs:`INTERFACE_COMPILE_DEFINITIONS` to pass additional preprocessor "
"definitions."
msgstr ""

#: ../../../prop_fs/INTERFACE_COMPILE_OPTIONS.rst:15
msgid ""
"Use :prop_fs:`INTERFACE_INCLUDE_DIRECTORIES` to pass additional include "
"directories."
msgstr ""
