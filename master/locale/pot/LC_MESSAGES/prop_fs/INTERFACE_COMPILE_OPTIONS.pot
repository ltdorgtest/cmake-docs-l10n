#: ../../../prop_fs/INTERFACE_COMPILE_OPTIONS.rst:2
msgid "INTERFACE_COMPILE_OPTIONS"
msgstr ""

#: ../../../prop_fs/include/INTERFACE_BUILD_PROPERTY.rst:1
msgid "List of public |property_name| requirements for a file set."
msgstr ""

#: ../../../prop_fs/include/INTERFACE_BUILD_PROPERTY.rst:3
msgid ""
"File sets may populate this property to publish the |property_name| required "
"to compile the sources for the target.  The |command_name| command populates "
"this property."
msgstr ""

#: ../../../prop_fs/include/INTERFACE_BUILD_PROPERTY.rst:7
msgid ""
"When target dependencies are specified using :command:"
"`target_link_libraries`, CMake will read this property from file sets of all "
"target dependencies to determine the build properties of the consumer. These "
"build properties are only applied to the sources of the file sets. The other "
"sources of the consumer are unaffected."
msgstr ""

#: ../../../prop_fs/include/INTERFACE_BUILD_PROPERTY.rst:13
msgid ""
"Contents of |PROPERTY_INTERFACE_NAME| may use \"generator expressions\" with "
"the syntax ``$<...>``.  See the :manual:`cmake-generator-expressions(7)` "
"manual for available expressions.  See the :manual:`cmake-buildsystem(7)` -"
"manual for more on defining buildsystem properties."
msgstr ""

