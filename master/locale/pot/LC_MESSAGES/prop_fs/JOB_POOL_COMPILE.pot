#: ../../../prop_fs/JOB_POOL_COMPILE.rst:2
msgid "JOB_POOL_COMPILE"
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:6
msgid "Ninja only: Pool used for compiling."
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:8
msgid ""
"The number of parallel compile processes could be limited by defining pools "
"with the global :prop_gbl:`JOB_POOLS` property and then specifying here the "
"pool name."
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:12
msgid ""
"This allows to override the :prop_sf:`JOB_POOL_COMPILE` and :prop_tgt:"
"`JOB_POOL_COMPILE` values for specific source files within a same target."
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:16
msgid "For instance:"
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:18
msgid ""
"set_property(FILE_SET my_fileset TYPE SOURCE PROPERTY JOB_POOL_COMPILE "
"two_jobs)"
msgstr ""

#: ../../../prop_fs/JOB_POOL_COMPILE.rst:22
msgid "This property is undefined by default."
msgstr ""

