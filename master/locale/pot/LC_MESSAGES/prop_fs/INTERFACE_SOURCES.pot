#: ../../../prop_fs/INTERFACE_SOURCES.rst:2
msgid "INTERFACE_SOURCES"
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:6
msgid ""
"List of interface sources to compile into consuming targets. The :command:"
"`target_sources` command sets or adds to the ``INTERFACE_SOURCES`` file set "
"property for the file sets defined with the ``PUBLIC`` or ``INTERFACE`` "
"keyword and is the usual way to manipulate it."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:11
msgid ""
"Contents of ``INTERFACE_SOURCES`` may use :manual:`generator expressions "
"<cmake-generator-expressions(7)>`."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:14
msgid ""
"Each file must be in one of the base directories, or a subdirectory of one "
"of the base directories."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:17
msgid ""
"If relative paths are specified, they are considered relative to the "
"target's source directory."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:20
msgid ""
"The following behavior applies for the :prop_fs:`SOURCES` and "
"``INTERFACE_SOURCES`` file set properties, dependent on the value of the :"
"prop_fs:`SCOPE` file set property:"
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:24
msgid "``PRIVATE``"
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:25
msgid ""
"Only the :prop_fs:`SOURCES` property can be set. Any change to the "
"``INTERFACE_SOURCES`` property will be ignored."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:28
msgid "``PUBLIC``"
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:29
msgid ""
":prop_fs:`SOURCES` and ``INTERFACE_SOURCES`` properties will always have the "
"same content."
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:32
msgid "``INTERFACE``"
msgstr ""

#: ../../../prop_fs/INTERFACE_SOURCES.rst:33
msgid ""
"Only the ``INTERFACE_SOURCES`` property can be set. Any change to the :"
"prop_fs:`SOURCES` property will be ignored."
msgstr ""
