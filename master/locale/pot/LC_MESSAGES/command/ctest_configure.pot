#: ../../../command/ctest_configure.rst:2
msgid "ctest_configure"
msgstr ""

#: ../../../command/ctest_configure.rst:4
msgid "Perform the :ref:`CTest Configure Step` as a :ref:`Dashboard Client`."
msgstr ""

#: ../../../command/ctest_configure.rst:6
msgid ""
"ctest_configure([BUILD <build-dir>] [SOURCE <source-dir>] [APPEND]\n"
"                [OPTIONS <options>] [RETURN_VALUE <result-var>] [QUIET]\n"
"                [CAPTURE_CMAKE_ERROR <result-var>]\n"
"                [PRESET <preset>]\n"
"                [PRESETS_FILE <file>]\n"
"                )"
msgstr ""

#: ../../../command/ctest_configure.rst:15
msgid ""
"Configure the project build tree and record results in ``Configure.xml`` for "
"submission with the :command:`ctest_submit` command."
msgstr ""

#: ../../../command/ctest_configure.rst:18
msgid "The options are:"
msgstr ""

#: ../../../command/ctest_configure.rst:20
msgid "``BUILD <build-dir>``"
msgstr ""

#: ../../../command/ctest_configure.rst:21
msgid ""
"Specify the top-level build directory.  If not given, the :variable:"
"`CTEST_BINARY_DIRECTORY` variable is used."
msgstr ""

#: ../../../command/ctest_configure.rst:24
msgid "``SOURCE <source-dir>``"
msgstr ""

#: ../../../command/ctest_configure.rst:25
msgid ""
"Specify the source directory.  If not given, the :variable:"
"`CTEST_SOURCE_DIRECTORY` variable is used."
msgstr ""

#: ../../../command/ctest_configure.rst:28
msgid "``APPEND``"
msgstr ""

#: ../../../command/ctest_configure.rst:29
msgid ""
"Mark ``Configure.xml`` for append to results previously submitted to a "
"dashboard server since the last :command:`ctest_start` call. Append "
"semantics are defined by the dashboard server in use. This does *not* cause "
"results to be appended to a ``.xml`` file produced by a previous call to "
"this command."
msgstr ""

#: ../../../command/ctest_configure.rst:35
msgid "``OPTIONS <options>``"
msgstr ""

#: ../../../command/ctest_configure.rst:36
msgid ""
"Specify a :ref:`semicolon-separated list <CMake Language Lists>` of command-"
"line arguments to pass to the configuration tool. This option is ignored "
"when :variable:`CTEST_CONFIGURE_COMMAND` is used."
msgstr ""

#: ../../../command/ctest_configure.rst:40
msgid "``PRESET <preset>``"
msgstr ""

#: ../../../command/ctest_configure.rst:43
msgid ""
"Specify a :manual:`preset <cmake-presets(7)>` to use when configuring the "
"project.  Any value set in the CTest script will take priority over a "
"corresponding setting from the preset.  For example, the :variable:"
"`CTEST_BINARY_DIRECTORY` variable will override the :preset:"
"`configurePresets.binaryDir` setting from the chosen preset."
msgstr ""

#: ../../../command/ctest_configure.rst:49
msgid ""
"When a preset is specified, the :variable:`CTEST_CONFIGURE_COMMAND` variable "
"is ignored so that the preset is always honored."
msgstr ""

#: ../../../command/ctest_configure.rst:52
msgid ""
"See also the :variable:`CTEST_CONFIGURE_PRESET` and :variable:`CTEST_PRESET` "
"variables."
msgstr ""

#: ../../../command/ctest_configure.rst:55
msgid "``PRESETS_FILE <file>``"
msgstr ""

#: ../../../command/ctest_configure.rst:58
msgid ""
"Specify a :manual:`presets <cmake-presets(7)>` file to use instead of the "
"default ``CMakePresets.json`` in the source directory. A relative path is "
"interpreted relative to the source directory. Has no effect unless a preset "
"is selected via the ``PRESET`` argument or the :variable:"
"`CTEST_CONFIGURE_PRESET` or :variable:`CTEST_PRESET` variables."
msgstr ""

#: ../../../command/ctest_configure.rst:65
msgid "See also the :variable:`CTEST_PRESETS_FILE` variable."
msgstr ""

#: ../../../command/ctest_configure.rst:67
msgid "``RETURN_VALUE <result-var>``"
msgstr ""

#: ../../../command/ctest_configure.rst:68
msgid ""
"Store in the ``<result-var>`` variable the return value of the native "
"configuration tool."
msgstr ""

#: ../../../command/ctest_configure.rst:71
msgid "``CAPTURE_CMAKE_ERROR <result-var>``"
msgstr ""

#: ../../../command/ctest_configure.rst:74
msgid ""
"Store in the ``<result-var>`` variable ``-1`` if there are any errors "
"running the command and prevent :manual:`ctest(1)` from returning non-zero "
"if an error occurs."
msgstr ""

#: ../../../command/ctest_configure.rst:78
msgid "``QUIET``"
msgstr ""

#: ../../../command/ctest_configure.rst:81
msgid ""
"Suppress any CTest-specific non-error messages that would have otherwise "
"been printed to the console.  Output from the underlying configure command "
"is not affected."
msgstr ""
