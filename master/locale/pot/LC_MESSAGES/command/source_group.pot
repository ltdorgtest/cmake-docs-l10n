#: ../../../command/source_group.rst:2
msgid "source_group"
msgstr ""

#: ../../../command/source_group.rst:4
msgid ""
"Define a grouping for source files in IDE project generation. There are two "
"different signatures to create source groups."
msgstr ""

#: ../../../command/source_group.rst:8
msgid "Synopsis"
msgstr ""

#: ../../../command/source_group.rst:12
msgid ""
"source_group(`\\<group\\>`_ [FILES <src>...] [REGULAR_EXPRESSION <regex>]\n"
"                     [FILE_SETS <fileset>... TARGET <target>]...)\n"
"\n"
"source_group(`TREE`_ <root> [PREFIX <prefix>] [FILES <src>...])"
msgstr ""

#: ../../../command/source_group.rst:18
msgid "Overview"
msgstr ""

#: ../../../command/source_group.rst:20
msgid ""
"Defines a group into which sources will be placed in project files. This is "
"intended to set up file tabs in Visual Studio."
msgstr ""

#: ../../../command/source_group.rst:23
msgid ""
"The group is scoped in the directory where the command is called, and "
"applies to sources in targets created in that directory."
msgstr ""

#: ../../../command/source_group.rst:26
msgid ""
"If the file set or the source file matches multiple groups, the *last* group "
"that explicitly lists the file set with ``FILE_SETS`` or the file with "
"``FILES`` will be favored, if any."
msgstr ""

#: ../../../command/source_group.rst:30
msgid ""
"To determine the group of a source file, the algorithm used is as follows:"
msgstr ""

#: ../../../command/source_group.rst:32
msgid "The file is part of a file set:"
msgstr ""

#: ../../../command/source_group.rst:34
msgid "Use the :prop_fs:`SOURCE_GROUP` file set property if any."
msgstr ""

#: ../../../command/source_group.rst:35
msgid "Search for the *last* group which explicitly lists this file set."
msgstr ""

#: ../../../command/source_group.rst:37
msgid ""
"The file is not part of a file set or no group was defined for this file set:"
msgstr ""

#: ../../../command/source_group.rst:40
msgid "Use the :prop_sf:`SOURCE_GROUP` source property if any."
msgstr ""

#: ../../../command/source_group.rst:41
msgid "Search for the *last* group which explicitly lists this source file."
msgstr ""

#: ../../../command/source_group.rst:43
msgid ""
"If no group explicitly lists the file set or the file, the *last* group "
"whose regular expression matches the file will be favored."
msgstr ""

#: ../../../command/source_group.rst:46
msgid ""
"The ``<group>`` and ``<prefix>`` arguments may contain forward slashes or "
"backslashes to specify subgroups.  Backslashes need to be escaped "
"appropriately:"
msgstr ""

#: ../../../command/source_group.rst:50
msgid ""
"source_group(base/subdir ...)\n"
"source_group(outer\\\\inner ...)\n"
"source_group(TREE <root> PREFIX sources\\\\inc ...)"
msgstr ""

#: ../../../command/source_group.rst:56
msgid "Allow using forward slashes (``/``) to specify subgroups."
msgstr ""

#: ../../../command/source_group.rst:60
msgid "Commands"
msgstr ""

#: ../../../command/source_group.rst:67 ../../../command/source_group.rst:108
msgid "The options are:"
msgstr ""

#: ../../../command/source_group.rst:69
msgid "``<group>``"
msgstr ""

#: ../../../command/source_group.rst:70
msgid "The name of the group."
msgstr ""

#: ../../../command/source_group.rst:72 ../../../command/source_group.rst:121
msgid "``FILES <src>...``"
msgstr ""

#: ../../../command/source_group.rst:73
msgid ""
"Any source file specified explicitly will be placed in group ``<group>``.  "
"Relative paths are interpreted with respect to the current source directory."
msgstr ""

#: ../../../command/source_group.rst:77 ../../../command/source_group.rst:125
msgid ""
"Arguments to ``FILES`` may use :manual:`generator expressions <cmake-"
"generator-expressions(7)>`."
msgstr ""

#: ../../../command/source_group.rst:81
msgid "``REGULAR_EXPRESSION <regex>``"
msgstr ""

#: ../../../command/source_group.rst:82
msgid ""
"Any source file whose name matches the regular expression will be placed in "
"group ``<group>``."
msgstr ""

#: ../../../command/source_group.rst:85
msgid "``FILE_SETS <fileset>...``"
msgstr ""

#: ../../../command/source_group.rst:88
msgid ""
"List of file sets. Files of these file sets will be placed in group "
"``<group>``. Arguments to ``FILE_SETS`` may use :manual:`generator "
"expressions <cmake-generator-expressions(7)>`."
msgstr ""

#: ../../../command/source_group.rst:92
msgid "``TARGET <target>``"
msgstr ""

#: ../../../command/source_group.rst:95
msgid ""
"Associate the file sets declared with the previous ``FILE_SETS`` keyword "
"with the target ``<target>``."
msgstr ""

#: ../../../command/source_group.rst:100
msgid ""
"The pattern ``FILE_SETS <fileset>... TARGET <target>`` can be repeated "
"multiple times."
msgstr ""

#: ../../../command/source_group.rst:110
msgid "``TREE <root>``"
msgstr ""

#: ../../../command/source_group.rst:111
msgid ""
"CMake will automatically detect, from ``<src>`` files paths, source groups "
"it needs to create, to keep structure of source groups analogically to the "
"actual files and directories structure in the project. Paths of ``<src>`` "
"files will be cut to be relative to ``<root>``. The command fails if the "
"paths within ``src`` do not start with ``root``."
msgstr ""

#: ../../../command/source_group.rst:117
msgid "``PREFIX <prefix>``"
msgstr ""

#: ../../../command/source_group.rst:118
msgid ""
"Source group and files located directly in ``<root>`` path, will be placed "
"in ``<prefix>`` source groups."
msgstr ""

#: ../../../command/source_group.rst:122
msgid ""
"List of files used to create source group structure. Relative paths are "
"interpreted with respect to the current source directory."
msgstr ""

#: ../../../command/source_group.rst:130
msgid "Legacy Support"
msgstr ""

#: ../../../command/source_group.rst:131
msgid "For backwards compatibility, the short-hand signature"
msgstr ""

#: ../../../command/source_group.rst:133
msgid "source_group(<name> <regex>)"
msgstr ""

#: ../../../command/source_group.rst:137
msgid "is equivalent to"
msgstr ""

#: ../../../command/source_group.rst:139
msgid "source_group(<name> REGULAR_EXPRESSION <regex>)"
msgstr ""
