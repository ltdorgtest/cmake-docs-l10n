#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:2
msgid "CMAKE_INSTALL_DEFAULT_COMPONENT_NAME"
msgstr ""

#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:4
msgid "Default component used in :command:`install` commands."
msgstr ""

#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:6
msgid ""
"If an :command:`install` command is used without the ``COMPONENT`` argument, "
"these files will be grouped into a default component.  The name of this "
"default install component will be taken from this variable.  It defaults to "
"``Unspecified``."
msgstr ""

#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:11
msgid "There is a special component name:"
msgstr ""

#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:13
msgid "``<PROJECT_NAME>``"
msgstr ""

#: ../../../variable/CMAKE_INSTALL_DEFAULT_COMPONENT_NAME.rst:16
msgid ""
"This literal placeholder will expand to the contents of the :variable:"
"`PROJECT_NAME` variable when the :command:`install` command is evaluated. If "
"no :command:`project` command has been called it defaults to ``Unspecified``."
msgstr ""
