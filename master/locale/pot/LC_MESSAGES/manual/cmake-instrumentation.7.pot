#: ../../../manual/cmake-instrumentation.7.rst:613
msgid ""
"The JSON format is described in machine-readable form by :download:`this "
"JSON schema </manual/instrumentation/snippet-v1-schema.json>`."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:620
msgid "v1 Index File"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:622
msgid ""
"Index files contain a list of `v1 Snippet Files <v1 Snippet File_>`_. It "
"serves as an entry point for navigating the instrumentation data. They are "
"generated whenever `Indexing`_ occurs and deleted after any user-specified "
"`Callbacks`_ are executed."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:628
msgid ""
"The `Data Version`_ of the index file, written as ``{ \"major\": 1, "
"\"minor\": N }`` where ``N`` is the most recent minor version."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:631
msgid "``buildDir``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:632
msgid "The build directory of the CMake project."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:634
msgid "``dataDir``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:635
msgid ""
"The full path to the ``<build>/.cmake/instrumentation/v1/data/`` directory."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:637
msgid "``hook``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:638
msgid ""
"The name of the hook responsible for generating the index file. In addition "
"to the hooks that can be specified by one of the `v1 Query Files`_, this "
"value may be set to ``manual`` if indexing is performed by invoking :option:"
"`ctest --collect-instrumentation`."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:643
msgid ""
"Note that the hook is not directly tied to what data may be available. A "
"``postBuild`` hook, for example, may include ``test`` or ``install`` "
"snippets, if these steps were run since the previous indexing."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:647
msgid "``snippets``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:648
msgid ""
"Contains a list of `v1 Snippet Files <v1 Snippet File_>`_. This includes all "
"snippet files generated since the previous index file was created. The file "
"paths are relative to ``dataDir``."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:652
msgid ""
"This list may be empty if indexing was run twice in succession, such as when "
"building multiple times with both the ``preBuild`` and ``postBuild`` hooks "
"enabled."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:657
msgid ""
"Contains the path to the `Google Trace File`_. This includes data from all "
"corresponding ``snippets`` in the index file. The file path is relative to "
"``dataDir``. Only included when enabled by the `v1 Query Files`_."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:662
msgid ""
"Specifies the static information collected about the host machine CMake is "
"being run from. If CMake is unable to determine the value of any given "
"field, it will be ``null``. See :command:`cmake_host_system_information` for "
"a description of each of the following fields."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:667
msgid "Only included when enabled by the `v1 Query Files`_."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:669
msgid "``OSName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:670
msgid "``OSPlatform``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:671
msgid "``OSRelease``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:672
msgid "``OSVersion``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:673
msgid "``familyId``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:674
msgid "``hostname``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:675
msgid "``is64Bits``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:676
msgid "``modelId``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:677
msgid "``modelName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:678
msgid "``numberOfLogicalCPU``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:679
msgid "``numberOfPhysicalCPU``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:680
msgid "``processorAPICID``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:681
msgid "``processorCacheSize``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:682
msgid "``processorClockFrequency``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:683
msgid "``processorName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:684
msgid "``totalPhysicalMemory``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:685
msgid "``totalVirtualMemory``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:686
msgid "``vendorID``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:687
msgid "``vendorString``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:691
msgid ""
"{\n"
"  \"version\": {\n"
"    \"major\": 1,\n"
"    \"minor\": 0\n"
"  },\n"
"  \"hook\": \"manual\",\n"
"  \"buildDir\": \"<build>\",\n"
"  \"dataDir\": \"<build>/.cmake/instrumentation/v1/data\",\n"
