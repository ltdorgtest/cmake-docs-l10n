#: ../../../manual/cmake-generator-expressions.7.rst:2537
msgid ":ref:`Custom Transitive Properties`"
msgstr ""

#: ../../../manual/cmake-generator-expressions.7.rst:2540
msgid "These are processed during evaluation as follows:"
