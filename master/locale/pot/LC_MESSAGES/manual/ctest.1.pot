#: ../../../manual/ctest.1.rst:4
msgid "ctest(1)"
msgstr ""

#: ../../../manual/ctest.1.rst:6
msgid "Contents"
msgstr ""

#: ../../../manual/ctest.1.rst:9
msgid "Synopsis"
msgstr ""

#: ../../../manual/ctest.1.rst:13
msgid ""
"`Run Tests`_\n"
" ctest [<options>...] [--test-dir <path-to-build>] [-- <test-args>...]\n"
"\n"
"`Build and Test Mode`_\n"
" ctest --build-and-test <path-to-source> <path-to-build>\n"
"       --build-generator <generator> [<options>...]\n"
"      [--build-options <opts>...]\n"
"      [--test-command <command> [<args>...]]\n"
"\n"
"`Dashboard Client`_\n"
" ctest -D <dashboard>            [-- <dashboard-options>...]\n"
" ctest -M <model> -T <action>    [-- <dashboard-options>...]\n"
" ctest [-M <model>] -T Configure --source-dir <path-to-source>\n"
"                                 [--build-dir <path-to-build>]\n"
"                                 [-- <dashboard-options>...]\n"
" ctest -S <script>               [-- <dashboard-options>...]\n"
" ctest -SP <script>              [-- <dashboard-options>...]\n"
"\n"
"`View Help`_\n"
" ctest --help[-<topic>]"
msgstr ""

#: ../../../manual/ctest.1.rst:36
msgid "Description"
msgstr ""

#: ../../../manual/ctest.1.rst:38
msgid ""
"The :program:`ctest` executable is the CMake test driver program. CMake-"
"generated build trees created for projects that use the :command:"
"`enable_testing` and :command:`add_test` commands have testing support. This "
"program will run the tests and report results."
msgstr ""

#: ../../../manual/ctest.1.rst:46
msgid "Run Tests"
msgstr ""

#: ../../../manual/ctest.1.rst:48
msgid ""
":program:`ctest` runs tests defined by a ``CTestTestfile.cmake`` file, "
"typically in a build tree generated by :manual:`cmake(1)`:"
msgstr ""

#: ../../../manual/ctest.1.rst:51
msgid "ctest [<options>...] [--test-dir <path-to-build>] [-- <test-args>...]"
msgstr ""

#: ../../../manual/ctest.1.rst:55
msgid ""
"If all tests pass, the exit code is ``0``.  The exit code is non-zero in the "
"following cases:"
msgstr ""

#: ../../../manual/ctest.1.rst:58
msgid "An error occurs, such as failure to process invalid arguments."
msgstr ""

#: ../../../manual/ctest.1.rst:60
msgid "No arguments are given and no ``CTestTestfile.cmake`` exists."
msgstr ""

#: ../../../manual/ctest.1.rst:63
msgid ""
"The :ctest-option:`--no-tests=error` argument is given and no tests are "
"executed, e.g., when ``CTestTestfile.cmake`` defines no tests, or when the "
"given arguments exclude all tests."
msgstr ""

#: ../../../manual/ctest.1.rst:67
msgid "At least one test fails."
msgstr ""

#: ../../../manual/ctest.1.rst:69
msgid "The options for running tests are:"
msgstr ""

#: ../../../manual/ctest.1.rst:75
msgid ""
"Use a test :manual:`preset <cmake-presets(7)>` to specify test options. The "
"project binary directory is inferred from the :preset:`testPresets."
"configurePreset` key."
msgstr ""

#: ../../../manual/ctest.1.rst:79
msgid ""
"The :ctest-option:`--test-dir` option may be specified with a different "
"binary directory than the one specified by the :preset:`testPresets."
"configurePreset` key."
msgstr ""

#: ../../../manual/ctest.1.rst:84
msgid ""
"If :ctest-option:`--presets-file` is specified, neither of ``CMakePresets."
"json`` nor ``CMakeUserPresets.json`` are required to be present.  Otherwise, "
"they are required to be present in the top level  source directory.  In "
"prior versions, this was strictly required."
msgstr ""

#: ../../../manual/ctest.1.rst:94
msgid ""
"Reads :manual:`presets <cmake-presets(7)>` from the given ``<file>``. The "
"specified path may be absolute or relative to the current working directory. "
"If ``--presets-file`` is given, presets defined in ``CMakePresets.json`` and "
"``CMakeUserPresets.json`` will be ignored."
msgstr ""

#: ../../../manual/ctest.1.rst:101
msgid ""
"Lists the available test presets. The current working directory must contain "
"``CMakePresets.json`` and/or ``CMakeUserPresets.json``."
msgstr ""

#: ../../../manual/ctest.1.rst:104
msgid ""
"If :ctest-option:`--presets-file` is specified, neither of ``CMakePresets."
"json`` nor ``CMakeUserPresets.json`` are required to be present, and only "
"presets defined in the given ``<file>`` will be listed. Otherwise, they are "
"required to be present in the top level source directory.  In prior "
"versions, this was strictly required."
msgstr ""

#: ../../../manual/ctest.1.rst:113
msgid "Choose configuration to test."
msgstr ""

#: ../../../manual/ctest.1.rst:115
msgid ""
"Some CMake-generated build trees can have multiple build configurations in "
"the same tree.  This option can be used to specify which one should be "
"tested.  Example configurations are ``Debug`` and ``Release``."
msgstr ""

#: ../../../manual/ctest.1.rst:122
msgid "Enable short progress output from tests."
msgstr ""

#: ../../../manual/ctest.1.rst:124
msgid ""
"When the output of :program:`ctest` is being sent directly to a terminal, "
"the progress through the set of tests is reported by updating the same line "
"rather than printing start and end messages for each test on new lines. This "
"can significantly reduce the verbosity of the test output. Test completion "
"messages are still output on their own line for failed tests and the final "
"test summary will also still be logged."
msgstr ""

#: ../../../manual/ctest.1.rst:131
msgid ""
"This option can also be enabled by setting the environment variable :envvar:"
"`CTEST_PROGRESS_OUTPUT`."
msgstr ""

#: ../../../manual/ctest.1.rst:136
msgid "Enable verbose output from tests."
msgstr ""

#: ../../../manual/ctest.1.rst:138
msgid ""
"Test output is normally suppressed and only summary information is "
"displayed.  This option will show all test output."
msgstr ""

#: ../../../manual/ctest.1.rst:143
msgid "Enable more verbose output from tests."
msgstr ""

#: ../../../manual/ctest.1.rst:145
msgid ""
"Test output is normally suppressed and only summary information is "
"displayed.  This option will show even more test output."
msgstr ""

#: ../../../manual/ctest.1.rst:150
msgid "Displaying more verbose internals of CTest."
msgstr ""

#: ../../../manual/ctest.1.rst:152
msgid ""
"This feature will result in a large number of output that is mostly useful "
"for debugging dashboard problems."
msgstr ""

#: ../../../manual/ctest.1.rst:157
msgid ""
"Output anything outputted by the test program if the test should fail. This "
"option can also be enabled by setting the :envvar:`CTEST_OUTPUT_ON_FAILURE` "
"environment variable."
msgstr ""

#: ../../../manual/ctest.1.rst:163
msgid "Stop running the tests when the first failure happens."
msgstr ""

#: ../../../manual/ctest.1.rst:167
msgid "Enable failover."
msgstr ""

#: ../../../manual/ctest.1.rst:169
msgid ""
"This option allows CTest to resume a test set execution that was previously "
"interrupted.  If no interruption occurred, the ``-F`` option will have no "
"effect."
msgstr ""

#: ../../../manual/ctest.1.rst:175
msgid ""
"Run tests in parallel, optionally limited to a given level of parallelism."
msgstr ""

#: ../../../manual/ctest.1.rst:179
msgid "The ``<level>`` may be omitted, or ``0``, in which case:"
msgstr ""

#: ../../../manual/ctest.1.rst:181
msgid ""
"Under `Job Server Integration`_, parallelism is limited by available job "
"tokens."
msgstr ""

#: ../../../manual/ctest.1.rst:184
msgid ""
"Otherwise, if the value is omitted, parallelism is limited by the number of "
"processors, or 2, whichever is larger."
msgstr ""

#: ../../../manual/ctest.1.rst:187
msgid "Otherwise, if the value is ``0``, parallelism is unbounded."
msgstr ""

#: ../../../manual/ctest.1.rst:189
msgid ""
"This option may instead be specified by the :envvar:`CTEST_PARALLEL_LEVEL` "
"environment variable."
msgstr ""

#: ../../../manual/ctest.1.rst:192
msgid ""
"This option can be used with the :prop_test:`PROCESSORS` test property. See "
"the `Label and Subproject Summary`_."
msgstr ""

#: ../../../manual/ctest.1.rst:197
msgid ""
"Run CTest with :ref:`resource allocation <ctest-resource-allocation>` "
"enabled, using the :ref:`resource specification file <ctest-resource-"
"specification-file>` specified in ``<file>``."
msgstr ""

#: ../../../manual/ctest.1.rst:202
msgid ""
"When :program:`ctest` is run as a `Dashboard Client`_ this sets the "
"``ResourceSpecFile`` option of the `CTest Test Step`_."
msgstr ""

#: ../../../manual/ctest.1.rst:207 ../../../manual/ctest.1.rst:1487
msgid ""
"While running tests in parallel (e.g. with :ctest-option:`-j`), try not to "
"start tests when they may cause the CPU load to pass above a given threshold."
msgstr ""

#: ../../../manual/ctest.1.rst:210
msgid ""
"When :program:`ctest` is run as a `Dashboard Client`_ this sets the "
"``TestLoad`` option of the `CTest Test Step`_."
msgstr ""

#: ../../../manual/ctest.1.rst:215
msgid "Make CTest quiet."
msgstr ""

#: ../../../manual/ctest.1.rst:217
msgid ""
"This option will suppress all the output.  The output log file will still be "
"generated if the :ctest-option:`--output-log` is specified. Options such as :"
"ctest-option:`--verbose`, :ctest-option:`--extra-verbose`, and :ctest-option:"
"`--debug` are ignored if ``--quiet`` is specified."
msgstr ""

#: ../../../manual/ctest.1.rst:226
msgid "Output to log file."
msgstr ""

#: ../../../manual/ctest.1.rst:228
msgid ""
"This option tells CTest to write all its output to a ``<file>`` log file."
msgstr ""

#: ../../../manual/ctest.1.rst:234
msgid "Write test results in JUnit format."
msgstr ""

#: ../../../manual/ctest.1.rst:236
msgid ""
"This option tells CTest to write test results to ``<file>`` in JUnit XML "
"format. If ``<file>`` already exists, it will be overwritten. If using the :"
"ctest-option:`-S` option to run a dashboard script, use the ``OUTPUT_JUNIT`` "
"keyword with the :command:`ctest_test` command instead."
msgstr ""

#: ../../../manual/ctest.1.rst:243
msgid "Disable actual execution of tests."
msgstr ""

#: ../../../manual/ctest.1.rst:245
msgid ""
"This option tells CTest to list the tests that would be run but not actually "
"run them.  Useful in conjunction with the :ctest-option:`-R` and :ctest-"
"option:`-E` options."
msgstr ""

#: ../../../manual/ctest.1.rst:251
msgid "The ``--show-only`` option accepts a ``<format>`` value."
msgstr ""

#: ../../../manual/ctest.1.rst:253
msgid "``<format>`` can be one of the following values."
msgstr ""

#: ../../../manual/ctest.1.rst:255
msgid "``human``"
msgstr ""

#: ../../../manual/ctest.1.rst:256
msgid ""
"Human-friendly output.  This is not guaranteed to be stable. This is the "
"default."
msgstr ""

#: ../../../manual/ctest.1.rst:259
msgid "``json-v1``"
msgstr ""

#: ../../../manual/ctest.1.rst:260
msgid ""
"Dump the test information in JSON format. See `Show as JSON Object Model`_."
msgstr ""

#: ../../../manual/ctest.1.rst:265
msgid ""
"Run tests with labels matching regular expression as described under :ref:"
"`string(REGEX) <Regex Specification>`."
msgstr ""

#: ../../../manual/ctest.1.rst:268
msgid ""
"This option tells CTest to run only the tests whose labels match the given "
"regular expression.  When more than one ``-L`` option is given, a test will "
"only be run if each regular expression matches at least one of the test's "
"labels (i.e. the multiple ``-L`` labels form an ``AND`` relationship).  See "
"`Label Matching`_."
msgstr ""

#: ../../../manual/ctest.1.rst:276
msgid "Run tests matching regular expression."
msgstr ""

#: ../../../manual/ctest.1.rst:278
msgid ""
"This option tells CTest to run only the tests whose names match the given "
"regular expression."
msgstr ""

#: ../../../manual/ctest.1.rst:283
msgid "Exclude tests matching regular expression."
msgstr ""

#: ../../../manual/ctest.1.rst:285
msgid ""
"This option tells CTest to NOT run the tests whose names match the given "
"regular expression."
msgstr ""

#: ../../../manual/ctest.1.rst:290
msgid "Exclude tests with labels matching regular expression."
msgstr ""

#: ../../../manual/ctest.1.rst:292
msgid ""
"This option tells CTest to NOT run the tests whose labels match the given "
"regular expression.  When more than one ``-LE`` option is given, a test will "
"only be excluded if each regular expression matches at least one of the "
"test's labels (i.e. the multiple ``-LE`` labels form an ``AND`` "
"relationship).  See `Label Matching`_."
msgstr ""

#: ../../../manual/ctest.1.rst:302
msgid "Run tests listed in the given file."
msgstr ""

#: ../../../manual/ctest.1.rst:304
msgid ""
"This option tells CTest to run tests that are listed in the given file. The "
"file must contain one exact test name per line. Lines that do not exactly "
"match any test names are ignored. This option can be combined with the other "
"options like :ctest-option:`-R`, :ctest-option:`-E`, :ctest-option:`-L`, or :"
"ctest-option:`-LE`."
msgstr ""

#: ../../../manual/ctest.1.rst:315
msgid "Exclude tests listed in the given file."
msgstr ""

#: ../../../manual/ctest.1.rst:317
msgid ""
"This option tells CTest to NOT run tests that are listed in the given file. "
"The file must contain one exact test name per line. Lines that do not "
"exactly match any test names are ignored. This option can be combined with "
"the other options like :ctest-option:`-R`, :ctest-option:`-E`, :ctest-option:"
"`-L`, or :ctest-option:`-LE`."
msgstr ""

#: ../../../manual/ctest.1.rst:326
msgid ""
"Exclude fixtures matching ``<regex>`` from automatically adding any tests to "
"the test set."
msgstr ""

#: ../../../manual/ctest.1.rst:329
msgid ""
"If a test in the set of tests to be executed requires a particular fixture, "
"that fixture's setup and cleanup tests would normally be added to the test "
"set automatically. This option prevents adding setup or cleanup tests for "
"fixtures matching the ``<regex>``. Note that all other fixture behavior is "
"retained, including test dependencies and skipping tests that have fixture "
"setup tests that fail."
msgstr ""

#: ../../../manual/ctest.1.rst:338
msgid ""
"Same as :ctest-option:`-FA` except only matching setup tests are excluded."
msgstr ""

#: ../../../manual/ctest.1.rst:342
msgid ""
"Same as :ctest-option:`-FA` except only matching cleanup tests are excluded."
msgstr ""

#: ../../../manual/ctest.1.rst:346
msgid "Run a specific number of tests by number."
msgstr ""

#: ../../../manual/ctest.1.rst:348
msgid ""
"This option causes CTest to run tests starting at number ``Start``, ending "
"at number ``End``, and incrementing by ``Stride``.  Any additional numbers "
"after ``Stride`` are considered individual test numbers.  ``Start``, "
"``End``, or ``Stride`` can be empty.  Optionally a file can be given that "
"contains the same syntax as the command line."
msgstr ""

#: ../../../manual/ctest.1.rst:356
msgid "Take the Union of :ctest-option:`-I` and :ctest-option:`-R`."
msgstr ""

#: ../../../manual/ctest.1.rst:358
msgid ""
"When both :ctest-option:`-R` and :ctest-option:`-I` are specified by default "
"the intersection of tests are run.  By specifying ``-U`` the union of tests "
"is run instead."
msgstr ""

#: ../../../manual/ctest.1.rst:364
msgid "Run only the tests that failed previously."
msgstr ""

#: ../../../manual/ctest.1.rst:366
msgid ""
"This option tells CTest to perform only the tests that failed during its "
"previous run.  When this option is specified, CTest ignores all other "
"options intended to modify the list of tests to run ( :ctest-option:`-L`, :"
"ctest-option:`-R`, :ctest-option:`-E`, :ctest-option:`-LE`, :ctest-option:`-"
"I`, etc).  In the event that CTest runs and no tests fail, subsequent calls "
"to CTest with the ``--rerun-failed`` option will run the set of tests that "
"most recently failed (if any)."
msgstr ""

#: ../../../manual/ctest.1.rst:377
msgid ""
"Run tests repeatedly based on the given ``<mode>`` up to ``<n>`` times. The "
"modes are:"
msgstr ""

#: ../../../manual/ctest.1.rst:380
msgid "``until-fail``"
msgstr ""

#: ../../../manual/ctest.1.rst:381
msgid ""
"Require each test to run ``<n>`` times without failing in order to pass. "
"This is useful in finding sporadic failures in test cases."
msgstr ""

#: ../../../manual/ctest.1.rst:384
msgid "``until-pass``"
msgstr ""

#: ../../../manual/ctest.1.rst:385
msgid ""
"Allow each test to run up to ``<n>`` times in order to pass. Repeats tests "
"if they fail for any reason. This is useful in tolerating sporadic failures "
"in test cases."
msgstr ""

#: ../../../manual/ctest.1.rst:389
msgid "``after-timeout``"
msgstr ""

#: ../../../manual/ctest.1.rst:390
msgid ""
"Allow each test to run up to ``<n>`` times in order to pass. Repeats tests "
"only if they timeout. This is useful in tolerating sporadic timeouts in test "
"cases on busy machines."
msgstr ""

#: ../../../manual/ctest.1.rst:397
msgid "Equivalent to :option:`--repeat until-fail:\\<n\\> <ctest --repeat>`."
msgstr ""

#: ../../../manual/ctest.1.rst:401
msgid "Set the max width for a test name to output."
msgstr ""

#: ../../../manual/ctest.1.rst:403
msgid ""
"Set the maximum width for each test name to show in the output. This allows "
"the user to widen the output to avoid clipping the test name which can be "
"very annoying."
msgstr ""

#: ../../../manual/ctest.1.rst:409
msgid "Disable (``0``) or enable (``1``) interactive debug mode."
msgstr ""

#: ../../../manual/ctest.1.rst:411
msgid ""
"This option causes CTest to run tests in either an interactive mode or a non-"
"interactive mode.  In dashboard mode (``Experimental``, ``Nightly``, "
"``Continuous``), the default is non-interactive.  In non-interactive mode, "
"the environment variable :envvar:`DASHBOARD_TEST_FROM_CTEST` is set."
msgstr ""

#: ../../../manual/ctest.1.rst:416
msgid ""
"Interactive Mode allows Windows Error Reporting (WER) to show debug popup "
"windows and to create core dumps.  To enable core dumps in tests, use "
"interactive mode, and follow the Windows documentation on `Collecting User-"
"Mode Dumps`_."
msgstr ""

#: ../../../manual/ctest.1.rst:421
msgid ""
"Windows Error Reporting (WER) is enabled in interactive mode, so test "
"processes may show debug popup windows and create core dumps. This was made "
"possible by updates to ``libuv``."
msgstr ""

#: ../../../manual/ctest.1.rst:426
msgid ""
"Windows Error Reporting (WER) is disabled in both interactive and non-"
"interactive modes, so test processes do not show popup windows or create "
"core dumps.  This is due to launching test processes with ``libuv``."
msgstr ""

#: ../../../manual/ctest.1.rst:436
msgid "Disable timing summary information for labels."
msgstr ""

#: ../../../manual/ctest.1.rst:438
msgid ""
"This option tells CTest not to print summary information for each label "
"associated with the tests run.  If there are no labels on the tests, nothing "
"extra is printed."
msgstr ""

#: ../../../manual/ctest.1.rst:442 ../../../manual/ctest.1.rst:452
#: ../../../manual/ctest.1.rst:1363 ../../../manual/ctest.1.rst:1416
#: ../../../manual/ctest.1.rst:1484
msgid "See `Label and Subproject Summary`_."
msgstr ""

#: ../../../manual/ctest.1.rst:446
msgid "Disable timing summary information for subprojects."
msgstr ""

#: ../../../manual/ctest.1.rst:448
msgid ""
"This option tells CTest not to print summary information for each subproject "
"associated with the tests run.  If there are no subprojects on the tests, "
"nothing extra is printed."
msgstr ""

#: ../../../manual/ctest.1.rst:458
msgid ""
"Specify the directory in which to look for tests, typically a CMake project "
"build directory. If not specified, the current directory is used. See also :"
"ctest-dashboard-option:`--build-dir`."
msgstr ""

#: ../../../manual/ctest.1.rst:466
msgid "Limit the output for passed tests to ``<size>`` bytes."
msgstr ""

#: ../../../manual/ctest.1.rst:472
msgid "Limit the output for failed tests to ``<size>`` bytes."
msgstr ""

#: ../../../manual/ctest.1.rst:478
msgid ""
"Truncate ``tail`` (default), ``middle`` or ``head`` of test output once "
"maximum output size is reached."
msgstr ""

#: ../../../manual/ctest.1.rst:483
msgid "Overwrite CTest configuration option."
msgstr ""

#: ../../../manual/ctest.1.rst:485
msgid ""
"By default CTest uses configuration options from configuration file. This "
"option will overwrite the configuration option."
msgstr ""

#: ../../../manual/ctest.1.rst:490
msgid ""
"Ignored.  This option once disabled a now-removed optimization for tests "
"running :program:`ctest` itself."
msgstr ""

#: ../../../manual/ctest.1.rst:495
msgid "Use a random order for scheduling tests."
msgstr ""

#: ../../../manual/ctest.1.rst:497
msgid ""
"This option will run the tests in a random order.  It is commonly used to "
"detect implicit dependencies in a test suite."
msgstr ""

#: ../../../manual/ctest.1.rst:504
msgid "Override the random order seed."
msgstr ""

#: ../../../manual/ctest.1.rst:506
msgid ""
"This option is used to allow recreating failures owing to random order of "
"execution by :ctest-option:`--schedule-random`."
msgstr ""

#: ../../../manual/ctest.1.rst:511
msgid "Legacy option for old Dart2 dashboard server feature. Do not use."
msgstr ""

#: ../../../manual/ctest.1.rst:516
msgid "Set the default test timeout."
msgstr ""

#: ../../../manual/ctest.1.rst:518
msgid ""
"This option effectively sets a timeout on all tests that do not already have "
"a timeout set on them via the :prop_test:`TIMEOUT` property."
msgstr ""

#: ../../../manual/ctest.1.rst:524
msgid "Set a time at which all tests should stop running."
msgstr ""

#: ../../../manual/ctest.1.rst:526
msgid ""
"Set a real time of day at which all tests should timeout.  Example: "
"``7:00:00 -0400``.  Any time format understood by the curl date parser is "
"accepted.  Local time is assumed if no timezone is specified."
msgstr ""

#: ../../../manual/ctest.1.rst:532
msgid "Print all available test labels."
msgstr ""

#: ../../../manual/ctest.1.rst:534
msgid ""
"This option will not run any tests, it will simply print the list of all "
"labels associated with the test set."
msgstr ""

#: ../../../manual/ctest.1.rst:539
msgid ""
"Specify behavior when no tests are executed, e.g., when ``CTestTestfile."
"cmake`` defines no tests, or when the given arguments exclude all tests.  "
"The ``<action>`` may be one of:"
msgstr ""

#: ../../../manual/ctest.1.rst:543
msgid "``error``"
msgstr ""

#: ../../../manual/ctest.1.rst:544
msgid "Consider running no tests to be an error."
msgstr ""

#: ../../../manual/ctest.1.rst:546
msgid "This is the default when running :option:`ctest -S` scripts."
msgstr ""

#: ../../../manual/ctest.1.rst:548
msgid "``ignore``"
msgstr ""

#: ../../../manual/ctest.1.rst:549
msgid "Consider running no tests to be normal."
msgstr ""

#: ../../../manual/ctest.1.rst:551
msgid ""
"This is the default when `running tests <Run Tests_>`__ via the :program:"
"`ctest` command line, even when running as a `dashboard client <Dashboard "
"Client_>`__."
msgstr ""

#: ../../../manual/ctest.1.rst:557
msgid ""
"This option can also be set by setting the :envvar:`CTEST_NO_TESTS_ACTION` "
"environment variable."
msgstr ""

#: ../../../manual/ctest.1.rst:564
msgid ""
"Manually collect instrumentation data from the specified build directory. "
"See the :ref:`cmake-instrumentation Indexing` section of CMake "
"instrumentation for more details."
msgstr ""

#: ../../../manual/ctest.1.rst:572
msgid "Forward extra arguments to test executables."
msgstr ""

#: ../../../manual/ctest.1.rst:574
msgid ""
"All arguments after ``--`` are appended to the end of every executed test's "
"command line.  This is useful for passing options to test frameworks like "
"Google Test or doctest.  For example:"
msgstr ""

#: ../../../manual/ctest.1.rst:578
msgid ""
"ctest -R my_test -- --gtest_filter=SomeTest.Case\n"
"ctest --verbose -- --success"
msgstr ""

#: ../../../manual/ctest.1.rst:583
msgid ""
"All selected tests receive the same extra arguments. Use :ctest-option:`-R` "
"or :ctest-option:`-L` to limit which tests are executed."
msgstr ""

#: ../../../manual/ctest.1.rst:587
msgid "A bare ``--`` with no following arguments is silently ignored."
msgstr ""

