msgstr ""

#: ../../../manual/presets/architecture-properties.rst:11
#: ../../../manual/presets/toolset-properties.rst:11
msgid "``strategy``"
msgstr ""

#: ../../../manual/presets/architecture-properties.rst:12
#: ../../../manual/presets/toolset-properties.rst:12
msgid ""
"An optional string telling CMake how to handle the field. Valid values are:"
msgstr ""

#: ../../../manual/presets/architecture-properties.rst:15
#: ../../../manual/presets/toolset-properties.rst:15
msgid "``\"set\"``"
