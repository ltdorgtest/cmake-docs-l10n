msgstr ""

#: ../../../manual/cmake-presets.7.rst:465
#: ../../../manual/cmake-presets.7.rst:480
msgid "Changes to `Configure Presets <Configure Preset_>`_:"
msgstr ""

#: ../../../manual/cmake-presets.7.rst:467
msgid "The :preset:`configurePresets.graphviz` field was added."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:469
msgid "``11``"
msgstr ""

