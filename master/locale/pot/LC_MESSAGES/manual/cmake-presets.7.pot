#: ../../../manual/presets/buildPresets-properties.rst:54
#: ../../../manual/presets/configurePresets-properties.rst:53
#: ../../../manual/presets/packagePresets-properties.rst:51
#: ../../../manual/presets/testPresets-properties.rst:53
#: ../../../manual/presets/workflowPresets-properties.rst:18
msgid ""
"An optional map containing vendor-specific information. CMake does not "
"interpret the contents of this field except to verify that it is a map if it "
"does exist. However, it should follow the same conventions as the root-level "
"``vendor`` field. If vendors use their own per-preset ``vendor`` field, they "
"should implement inheritance in a sensible manner when appropriate."
msgstr ""

