msgid "`Package Presets <Package Preset_>`_ were added."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:430
msgid "`Workflow Presets <Workflow Preset_>`_ were added."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:433
msgid ""
"The :preset:`testPresets.output.outputJUnitFile` field was added to the :"
"preset:`testPresets.output` object."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:436
msgid "``7``"
msgstr ""

#: ../../../manual/cmake-presets.7.rst:441
