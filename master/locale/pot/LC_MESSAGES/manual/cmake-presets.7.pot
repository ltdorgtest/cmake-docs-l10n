msgstr ""

#: ../../../manual/cmake-presets.7.rst:443
#: ../../../manual/cmake-presets.7.rst:455
msgid "Changes to `Includes`_"
msgstr ""

#: ../../../manual/cmake-presets.7.rst:445
msgid ""
"The :preset:`include` field now supports ``$penv{}`` `macro expansion`_."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:447
msgid "``8``"
msgstr ""

#: ../../../manual/cmake-presets.7.rst:450
msgid "The :preset:`$schema` field was added to the root object."
msgstr ""

#: ../../../manual/cmake-presets.7.rst:452
msgid "``9``"
msgstr ""

