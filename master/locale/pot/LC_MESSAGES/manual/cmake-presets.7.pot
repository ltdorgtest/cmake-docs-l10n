msgstr ""

#: ../../../manual/cmake-presets.7.rst:396
#: ../../../manual/cmake-presets.7.rst:410
#: ../../../manual/cmake-presets.7.rst:422
#: ../../../manual/cmake-presets.7.rst:492
msgid "Changes to `Macro Expansion`_"
msgstr ""

