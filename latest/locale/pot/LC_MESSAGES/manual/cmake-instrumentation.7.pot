#: ../../../manual/cmake-instrumentation.7.rst:533
msgid "v1 Index File"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:535
msgid ""
"Index files contain a list of `v1 Snippet Files <v1 Snippet File_>`_. It "
"serves as an entry point for navigating the instrumentation data. They are "
"generated whenever `Indexing`_ occurs and deleted after any user-specified "
"`Callbacks`_ are executed."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:541
msgid ""
"The `Data Version`_ of the index file, an integer. Currently the version is "
"always ``1``."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:544
msgid "``buildDir``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:545
msgid "The build directory of the CMake project."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:547
msgid "``dataDir``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:548
msgid ""
"The full path to the ``<build>/.cmake/instrumentation/v1/data/`` directory."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:550
msgid "``hook``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:551
msgid ""
"The name of the hook responsible for generating the index file. In addition "
"to the hooks that can be specified by one of the `v1 Query Files`_, this "
"value may be set to ``manual`` if indexing is performed by invoking :option:"
"`ctest --collect-instrumentation`."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:556
msgid ""
"Note that the hook is not directly tied to what data may be available. A "
"``postBuild`` hook, for example, may include ``test`` or ``install`` "
"snippets, if these steps were run since the previous indexing."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:560
msgid "``snippets``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:561
msgid ""
"Contains a list of `v1 Snippet Files <v1 Snippet File_>`_. This includes all "
"snippet files generated since the previous index file was created. The file "
"paths are relative to ``dataDir``."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:565
msgid ""
"This list may be empty if indexing was run twice in succession, such as when "
"building multiple times with both the ``preBuild`` and ``postBuild`` hooks "
"enabled."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:570
msgid ""
"Contains the path to the `Google Trace File`_. This includes data from all "
"corresponding ``snippets`` in the index file. The file path is relative to "
"``dataDir``. Only included when enabled by the `v1 Query Files`_."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:575
msgid ""
"Specifies the static information collected about the host machine CMake is "
"being run from. If CMake is unable to determine the value of any given "
"field, it will be ``null``. See :command:`cmake_host_system_information` for "
"a description of each of the following fields."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:580
msgid "Only included when enabled by the `v1 Query Files`_."
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:582
msgid "``OSName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:583
msgid "``OSPlatform``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:584
msgid "``OSRelease``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:585
msgid "``OSVersion``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:586
msgid "``familyId``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:587
msgid "``hostname``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:588
msgid "``is64Bits``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:589
msgid "``modelId``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:590
msgid "``modelName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:591
msgid "``numberOfLogicalCPU``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:592
msgid "``numberOfPhysicalCPU``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:593
msgid "``processorAPICID``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:594
msgid "``processorCacheSize``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:595
msgid "``processorClockFrequency``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:596
msgid "``processorName``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:597
msgid "``totalPhysicalMemory``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:598
msgid "``totalVirtualMemory``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:599
msgid "``vendorID``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:600
msgid "``vendorString``"
msgstr ""

#: ../../../manual/cmake-instrumentation.7.rst:604
msgid ""
"{\n"
"  \"version\": 1,\n"
"  \"hook\": \"manual\",\n"
"  \"buildDir\": \"<build>\",\n"
"  \"dataDir\": \"<build>/.cmake/instrumentation/v1/data\",\n"
"  \"snippets\": [\n"
"    \"configure-<hash>-<timestamp>.json\",\n"
"    \"generate-<hash>-<timestamp>.json\",\n"
